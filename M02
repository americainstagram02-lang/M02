class Checker:
    @staticmethod
    def hi2_in(email):
        # فحص إيميلات hi2.in وإمكانية الإنشاء
        url = f"https://api.hi2.in/v1/check?email={email}"
        try:
            r = requests.get(url, headers=get_headers(), timeout=10)
            if '"available":true' in r.text: return True
            return False
        except: return False

    @staticmethod
    def instagram(email):
        url = "https://www.instagram.com/api/v1/web/accounts/lookup_edit/"
        try:
            r = requests.post(url, headers=get_headers("insta"), data={'email': email}, timeout=10)
            return '"status":"ok"' in r.text
        except: return False

    @staticmethod
    def facebook(email):
        url = 'https://b-graph.facebook.com/recover_accounts'
