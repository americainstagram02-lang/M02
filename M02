# --- [ ADVANCED PLATFORM DISCOVERY ENGINE ] ---
class DiscoveryEngine:
    """هذا المحرك يحدد نوع المنصة المرتبطة بالحساب قبل صيده"""
    @staticmethod
    def check_linked_services(email):
        linked_info = []
        
        # 1. فحص إنستغرام (Instagram Discovery)
        try:
            r_insta = requests.post(
                'https://www.instagram.com/api/v1/web/accounts/lookup_edit/',
                headers=get_headers(),
                data={'email': email},
                timeout=5
            )
            if '"status":"ok"' in r_insta.text:
                linked_info.append(f"{F}Instagram{W}")
        except: pass

        # 2. فحص تيك توك (TikTok Discovery)
        try:
            r_tik = requests.get(
                f"https://www.tiktok.com/api/v1/check/email/?email={email}&aid=1233",
                headers=get_headers(),
                timeout=5
            )
            if r_tik.json().get('is_registered'):
                linked_info.append(f"{S}TikTok{W}")
        except: pass

        # 3. فحص فيسبوك (Facebook Discovery via Recovery)
        if FB_Bypass_Logic.check_activity(email):
            linked_info.append(f"{B}Facebook{W}")

        # 4. فحص سناب شات (Snapchat Discovery)
        try:
            r_snap = requests.post(
                "https://accounts.snapchat.com/accounts/get_email_status",
                headers=get_headers(),
                data={'email': email},
                timeout=5
            )
            if '"exists":true' in r_snap.text:
                linked_info.append(f"{X}Snapchat{W}")
        except: pass

        return linked_info

