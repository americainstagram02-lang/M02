# --- PROXY MANAGEMENT SYSTEM ---
class ProxyManager:
    def __init__(self):
        self.file = PROXIES_FILE
        self.used_file = USED_PROXIES

    def get_fresh_proxy(self):
        # Advanced logic: Get a proxy that hasn't been used in this session
        try:
            with open(self.file, 'r') as f:
                all_proxies = set(line.strip() for line in f if line.strip())
            
            if not all_proxies:
                return None
            
            if os.path.exists(self.used_file):
                with open(self.used_file, 'r') as f:
                    used = set(line.strip() for line in f if line.strip())
                fresh = list(all_proxies - used)
            else:
                fresh = list(all_proxies)

            if not fresh:
                return "EMPTY"

            selected = random.choice(fresh)
            
            # Mark as used immediately to prevent collision
            with open(self.used_file, 'a') as f:
                f.write(f"{selected}\n")
            
            return {"http": f"http://{selected}", "https": f"http://{selected}"}
        except Exception as e:
            SystemUtils.log(f"Proxy Error: {str(e)}", "ERROR")
            return None

