class MultiThreadController:
    """
    Handles multi-account creation without crashing the device.
    """
    def __init__(self, threads=2):
        # We limit threads to 2-3 for OPPO A16k to maintain stability
        self.max_threads = threads
        self.active_threads = []

    def run_bulk_task(self, email_list):
        UIComponents.show_progress(f"Starting Multi-Threaded Task (Threads: {self.max_threads})")
        for email in email_list:
            if len(self.active_threads) >= self.max_threads:
                # Wait for a thread to finish before starting new one
                for t in self.active_threads:
                    t.join()
                self.active_threads = []
                DeviceOptimizer.clear_cache()

            t = threading.Thread(target=RegistrationCore().initiate_new_account, args=(email,))
            t.start()
            self.active_threads.append(t)
            HumanBehavior.think(10, 20) # Space between account starts

