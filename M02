# --- مدير الحفظ الذكي (Smart Saver) ---
class MohaResultManager:
    def __init__(self):
        self.path = "database"
        if not os.path.exists(self.path): os.makedirs(self.path)

    def save_hit(self, platform, data):
        """حفظ النتائج فوراً لضمان عدم ضياعها على OPPO A16k"""
        filename = f"{self.path}/{platform.lower()}.txt"
        with open(filename, "a", encoding="utf-8") as f:
            f.write(f"{data}\n")

