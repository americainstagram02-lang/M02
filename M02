# --- [ SMART PASSWORD INJECTOR ] ---
def moha_smart_pass(user_data, raw_pw):
    """ Custom logic to inject data into passwords dynamically """
    if "|" not in user_data: return raw_pw
    
    parts = user_data.split('|')
    uid = parts[0]
    full_name = parts[1].lower()
    first_name = full_name.split(' ')[0]
    
    final_pw = raw_pw.replace("first", first_name).replace("FIRST", first_name)
    final_pw = final_pw.replace("id", uid).replace("ID", uid)
    
    # Handle short names (less than 3 chars)
    if len(first_name) < 3:
        return raw_pw if "first" not in raw_pw else first_name + "123"
        
    return final_pw

