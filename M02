class SecurityProtocol:
    @staticmethod
    def generate_meta_signature(payload):
        """
        Simulates the security signature (sig) required for 
        high-security Meta endpoints to prevent tampering.
        """
        sorted_payload = "".join(f"{k}={v}" for k, v in sorted(payload.items()))
        # Salted hash simulation (Meta uses similar logic for app requests)
        raw_sig = f"662a39348e1c2932347d4e1c251d2f2c{sorted_payload}"
        return hashlib.md5(raw_sig.encode('utf-8')).hexdigest()

class RequestInterceptor:
    """
    Main engine to handle sessions, cookies, and headers rotation.
    """
    def __init__(self):
        self.session = requests.Session()
        self.proxy_mgr = ProxyManager()
        self.current_proxy = None
        self.hardware = HardwareVault.generate_fingerprint()
        self.ua = HardwareVault.get_user_agent(self.hardware)

    def refresh_identity(self):
        # Full reset for a new account attempt
        self.session.cookies.clear()
        self.current_proxy = self.proxy_mgr.get_fresh_proxy()
        
        if self.current_proxy == "EMPTY":
            return "OUT_OF_PROXIES"
        if self.current_proxy:
            self.session.proxies.update(self.current_proxy)
            
        self.hardware = HardwareVault.generate_fingerprint()
        self.ua = HardwareVault.get_user_agent(self.hardware)
        return "SUCCESS"

    def get_headers(self, custom_referer=None):
        # Advanced headers to bypass Meta's anti-bot (Sec-Ch-Ua based)
        chrome_v = re.search(r"Chrome/(\d+)", self.ua).group(1) if "Chrome" in self.ua else "124"
        
        headers = {
            "User-Agent": self.ua,
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,*/*;q=0.8",
            "Accept-Language": "en-US,en;q=0.9,ar-DZ;q=0.8", # Prioritizing Algeria for credibility
            "Accept-Encoding": "gzip, deflate, br, zstd",
            "Connection": "keep-alive",
            "Upgrade-Insecure-Requests": "1",
            "Sec-Ch-Ua": f'"Chromium";v="{chrome_v}", "Not(A:Brand";v="24", "Google Chrome";v="{chrome_v}"',
            "Sec-Ch-Ua-Mobile": "?1",
            "Sec-Ch-Ua-Platform": '"Android"',
            "Sec-Fetch-Dest": "document",
            "Sec-Fetch-Mode": "navigate",
            "Sec-Fetch-Site": "none",
            "Sec-Fetch-User": "?1",
            "DNT": "1",
            "X-Fb-Http-Engine": "Liger", # Critical for mimicking FB infrastructure
            "X-Asbd-Id": "129477",       # Static security ID for current Meta builds
        }
        if custom_referer:
            headers["Referer"] = custom_referer
        return headers

class ResponseAnalyzer:
    """
    Analyzes Meta server responses to decide the next logic step.
    """
    @staticmethod
    def check_outcome(response):
        url = response.url.lower()
        html = response.text.lower()
        
        if "checkpoint" in url:
            return "CHECKPOINT", "Security checkpoint triggered (ID/Photo required)."
        elif "contactpoint" in url or "confirm" in url:
            return "SUCCESS_STEP_1", "Account initialized. Code sent to email."
        elif "reg_error_inner" in html:
            # Extracting specific error message from Meta's UI
            soup = BeautifulSoup(response.text, 'html.parser')
            err_box = soup.find('div', {'id': 'reg_error_inner'})
            msg = err_box.text if err_box else "Registration rejected by Meta servers."
            return "REJECTED", msg
        elif "captcha" in html:
            return "CAPTCHA", "Captcha required. IP might be flagged."
        
        return "UNKNOWN", "Server returned an unhandled response pattern."

