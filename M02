class SessionManager:
    """
    Handles loading and verifying saved cookies and hardware profiles.
    """
    @staticmethod
    def list_pending_accounts():
        # Lists all accounts that finished Step 1 and have saved sessions
        if not os.path.exists('sessions'):
            return []
        return [f.replace('.json', '') for f in os.listdir('sessions') if f.endswith('.json')]

    @staticmethod
    def load_full_context(email):
        # Restores both cookies and the specific hardware profile used for creation
        cookie_path = f"sessions/{email}.json"
        device_path = f"database/device_profiles/{email}.json"
        
        if os.path.exists(cookie_path) and os.path.exists(device_path):
            with open(cookie_path, 'r') as f:
                cookies = json.load(f)
            with open(device_path, 'r') as f:
                device_info = json.load(f)
            return cookies, device_info
        return None, None

class AccountChecker:
    """
    Professional tool to verify account status without triggering security alerts.
    """
    def __init__(self, email):
        self.email = email
        self.session = requests.Session()
        self.cookies, self.device = SessionManager.load_full_context(email)
        
    def verify_status(self):
        if not self.cookies:
            UIComponents.show_error(f"No saved session found for {self.email}")
            return "NO_SESSION"

        # Restore context
        self.session.cookies.update(self.cookies)
        ua = HardwareVault.get_user_agent(self.device)
        headers = {
            "User-Agent": ua,
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
            "Accept-Language": "en-US,en;q=0.9",
            "Connection": "keep-alive"
        }

        try:
            # Step 1: Check if we can still access the confirmation page
            UIComponents.show_progress(f"Checking health for: {self.email}...")
            response = self.session.get("https://mbasic.facebook.com/confirmemail.php", headers=headers, timeout=15)
            
            if "confirm" in response.url or "code" in response.text.lower():
                return "HEALTHY_WAITING_CODE"
            elif "checkpoint" in response.url:
                return "LOCKED_CHECKPOINT"
            elif "login" in response.url:
                return "SESSION_EXPIRED"
            else:
                return "UNKNOWN_REJECTED"
        except Exception as e:
            SystemUtils.log(f"Checker Error for {self.email}: {str(e)}", "ERROR")
            return "CONNECTION_FAILED"

