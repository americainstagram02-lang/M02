# --- [ DISCOVERY ENGINE: IDENTIFY LINKED PLATFORMS ] ---
class DiscoveryEngine:
    @staticmethod
    def check_linked_services(email):
        """فحص الإيميل في المنصات لتحديد نوع الصيد"""
        linked_info = []
        
        # Check Instagram
        try:
            r_insta = requests.post(
                'https://www.instagram.com/api/v1/web/accounts/lookup_edit/',
                headers=get_random_headers(),
                data={'email': email},
                timeout=5
            )
            if '"status":"ok"' in r_insta.text:
                linked_info.append("Instagram")
        except: pass

        # Check TikTok
        try:
            r_tik = requests.get(
                f"https://www.tiktok.com/api/v1/check/email/?email={email}&aid=1233",
                headers=get_random_headers(),
                timeout=5
            )
            if r_tik.json().get('is_registered'):
                linked_info.append("TikTok")
        except: pass

        # Check Facebook
        if FB_Bypass_Logic.check_activity(email):
            linked_info.append("Facebook")

        # Check Snapchat
        try:
            r_snap = requests.post(
                "https://accounts.snapchat.com/accounts/get_email_status",
                headers=get_headers(),
                data={'email': email},
                timeout=5
            )
            if '"exists":true' in r_snap.text:
                linked_info.append("Snapchat")
        except: pass

        return linked_info

# --- [ AVAILABILITY CHECKERS (GMAIL, MAIL.RU, HOTMAIL) ] ---
class AvailabilityCheckers:
    @staticmethod
    def gmail(email):
        url = f"https://mail.google.com/mail/gxlu?email={email}"
        try:
            time.sleep(random.uniform(0.1, 0.3))
            sess = requests.Session()
            r = sess.get(url, headers=get_random_headers("google"), timeout=10)
            
            if r.status_code in [403, 429]:
                return "BAN"
            
            cookie_str = str(sess.cookies.get_dict()) + str(r.headers)
            if 'COMPASS' in cookie_str:
                return False # Registered
            return True # Available
        except:
            return "ERROR"

    @staticmethod
    def mail_ru(email):
        url = f"https://account.mail.ru/api/v1/user/exists?email={email}"
        try:
            r = requests.get(url, headers=get_random_headers(), timeout=7)
            if r.status_code == 429: return "BAN"
            return True if '"exists":false' in r.text else False
        except:
            return "ERROR"

    @staticmethod
    def hotmail(email):
        url = "https://login.live.com/GetCredentialType.srf"
        payload = {"username": email, "isExternal": False, "checkRegion": "1", "getAccountResolution": "true"}
        try:
            r = requests.post(url, json=payload, headers=get_random_headers(), timeout=7)
            if r.status_code in [403, 429]: return "BAN"
            return True if '"IfExistsResult":5' in r.text else False
        except:
            return "ERROR"

