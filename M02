class DataManager:
    """نظام تقدير سنة إنشاء الحساب بناءً على الـ UID"""
    @staticmethod
    def get_year(uid):
        if uid.startswith('100000'): return '2009'
        elif uid.startswith('100001'): return '2010'
        elif uid.startswith('100002'): return '2011'
        elif uid.startswith('100003'): return '2012'
        elif uid.startswith('100004'): return '2013'
        elif uid.startswith('100005'): return '2014'
        return 'OLD'

    @staticmethod
    def save_result(uid, pw, status):
        path = "database/hits.txt" if status == "OK" else "database/cp.txt"
        if not os.path.exists('database'): os.makedirs('database')
        with open(path, "a") as f:
            f.write(f"{uid}|{pw}|{DataManager.get_year(uid)}\n")

