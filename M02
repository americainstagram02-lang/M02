class ProxyManager:
    def __init__(self):
        self.proxies = []
        self.last_update = 0

    def fetch_fresh_proxies(self):
        # سحب بروكسيات مجانية من مصادر متعددة لضمان استمرار الصيد
        if time.time() - self.last_update < 600: return
        try:
            sources = [
                "https://api.proxyscrape.com/?request=displayproxies&proxytype=http&timeout=1000&country=all",
                "https://www.proxy-list.download/api/v1/get?type=http",
                "https://raw.githubusercontent.com/TheSpeedX/SOCKS-List/master/http.txt"
            ]
            new_list = []
            for src in sources:
                try:
                    r = requests.get(src, timeout=10)
                    if r.status_code == 200:
                        new_list.extend(r.text.splitlines())
                except: continue
            self.proxies = list(set(new_list))
            self.last_update = time.time()
        except: pass

    def get_proxy(self):
        if not self.proxies: return None
        px = random.choice(self.proxies)
        return {"http": f"http://{px}", "https": f"http://{px}"}

