class UserGen:
    @staticmethod
    def create(prefix, length):
        chars = string.ascii_lowercase + string.digits
        if not prefix:
            return ''.join(random.choice(chars) for _ in range(length))
        if len(prefix) >= length:
            return prefix
        res = prefix
        while len(res) < length:
            res += random.choice(chars)
        return res

