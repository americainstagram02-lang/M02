class MoaktAPI:
    """
    Automated interface for hi2.in (Moakt) to fetch verification codes.
    """
    def __init__(self, email):
        self.session = requests.Session()
        self.email_prefix = email.split('@')[0]
        self.domain = email.split('@')[1]
        self.base_url = "https://www.moakt.com/ar/email"
        # Standard headers for Moakt web access
        self.headers = {
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
        }

    def fetch_inbox(self):
        # Access the inbox for the generated email prefix
        target_url = f"{self.base_url}/{self.email_prefix}/{self.domain}"
        try:
            UIComponents.show_progress(f"Checking Moakt inbox for {self.email_prefix}...")
            response = self.session.get(target_url, headers=self.headers, timeout=15)
            return response.text
        except Exception as e:
            UIComponents.show_error(f"Moakt Connection Failed: {str(e)}")
            return None

    def extract_fb_code(self):
        # Scraping the verification code from the inbox table
        html = self.fetch_inbox()
        if not html: return None
        
        # Look for the Facebook verification pattern (5 or 6 digits)
        # Pattern: FB-12345 or just 12345
        codes = re.findall(r'\b\d{5,6}\b', html)
        if codes:
            # Usually the most recent code is the first one found
            return codes[0]
        return None

class SecureDataVault:
    """
    Handles encryption of account data to prevent theft if the script is shared.
   
    """
    @staticmethod
    def simple_encrypt(text):
        # Basic Base64 + XOR simulation for lightweight protection on Android
        key = "MOHA02_SECRET"
        encrypted = ""
        for i in range(len(text)):
            encrypted += chr(ord(text[i]) ^ ord(key[i % len(key)]))
        return encrypted.encode('utf-8').hex()

    @staticmethod
    def simple_decrypt(hex_data):
        key = "MOHA02_SECRET"
        text = bytes.fromhex(hex_data).decode('utf-8')
        decrypted = ""
        for i in range(len(text)):
            decrypted += chr(ord(text[i]) ^ ord(key[i % len(key)]))
        return decrypted

class AccountActivator:
    """
    Logic to submit the verification code and finalize the account.
    """
    def __init__(self, email):
        self.email = email
        self.moakt = MoaktAPI(email)
        self.core = RegistrationCore()

    def try_auto_verify(self):
        # 1. Look for the code automatically
        UIComponents.show_progress("Waiting for Facebook verification code...")
        for attempt in range(1, 11): # Try for 5 minutes (30s intervals)
            code = self.moakt.extract_fb_code()
            if code:
                UIComponents.show_success(f"Code Found: {code}")
                return self.submit_code_to_fb(code)
            
            UIComponents.show_progress(f"Attempt {attempt}/10: Code not found yet. Retrying in 30s...")
            time.sleep(30)
        
        UIComponents.show_error("Automatic code retrieval timed out.")
        return False

    def submit_code_to_fb(self, code):
        # Restoration of session context
        cookies, device = SessionManager.load_full_context(self.email)
        if not cookies: return False
        
        session = requests.Session()
        session.cookies.update(cookies)
        ua = HardwareVault.get_user_agent(device)
        headers = {"User-Agent": ua, "Referer": "https://mbasic.facebook.com/confirmemail.php"}
        
        try:
            # Navigate to confirmation page
            conf_page = session.get("https://mbasic.facebook.com/confirmemail.php", headers=headers)
            soup = BeautifulSoup(conf_page.text, 'html.parser')
            
            # Extract form for code submission
            form = soup.find('form', method='post')
            if not form:
                UIComponents.show_error("Could not find confirmation form.")
                return False
            
            inputs = form.find_all('input')
            payload = {inp.get('name'): inp.get('value') for inp in inputs if inp.get('name')}
            
            # Update payload with the code
            # Note: Field name is usually 'c' or 'code' in mbasic
            code_field = 'c' if 'c' in payload else 'code'
            payload[code_field] = code
            payload['confirm'] = 'Confirm'
            
            UIComponents.show_progress("Submitting code to Meta...")
            res = session.post("https://mbasic.facebook.com" + form['action'], data=payload, headers=headers)
            
            if "home.php" in res.url or "checkpoint" not in res.url:
                UIComponents.show_success(f"Account {self.email} Verified Successfully!")
                return True
            else:
                UIComponents.show_error("Verification failed or account locked after code.")
                return False
        except Exception as e:
            UIComponents.show_error(f"Submission Error: {str(e)}")
            return False

