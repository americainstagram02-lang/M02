class MohaSessionManager:
    """نظام جلب الكوكيز الحقيقي قبل التسجيل لرفع نسبة النجاح"""
    def __init__(self, session):
        self.session = session
        self.ua = "Mozilla/5.0 (Linux; Android 11; OPPO A16k Build/RP1A.200720.011) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/94.0.4606.85 Mobile Safari/537.36"
        self.headers = {
            'authority': 'm.facebook.com',
            'accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8',
            'accept-language': 'en-US,en;q=0.9,ar-DZ;q=0.8,ar;q=0.7',
            'user-agent': self.ua,
            'sec-fetch-dest': 'document',
            'sec-fetch-mode': 'navigate',
            'sec-fetch-site': 'none',
            'upgrade-insecure-requests': '1',
        }

    def prepare_session(self):
        UIComponents.show_progress("Initializing secure session and fetching cookies")
        try:
            # الخطوة الأهم: زيارة صفحة التسجيل لجلب كوكيز datr و sb
            response = self.session.get("https://m.facebook.com/reg/", headers=self.headers, timeout=15)
            # استخراج التوكنات المخفية من الصفحة
            soup = BeautifulSoup(response.text, 'html.parser')
            reg_instance = soup.find('input', {'name': 'reg_instance'})
            if reg_instance:
                return reg_instance['value']
        except Exception as e:
            UIComponents.show_error(f"Session Error: {str(e)}")
        return str(uuid.uuid4())

class RegistrationEngine:
    """المحرك المعدل بدون بروكسي وبنظام المحاكاة العميقة"""
    def __init__(self):
        self.session = requests.Session()
        self.manager = MohaSessionManager(self.session)
        
    def run_manual_flow(self):
        SystemUtils.clear()
        SystemUtils.banner()
        
        # تحضير الجلسة أولاً
        reg_id = self.manager.prepare_session()
        UIComponents.show_info("Session stabilized via Local Network.")
        print(f"{W}--------------------------------------------")

        # طلب البيانات بالإنجليزية لتقليل الشك
        f_name = input(f"{C} [?] First Name: {G}")
        l_name = input(f"{C} [?] Last Name: {G}")
        day = input(f"{C} [?] Day (DD): {G}")
        month = input(f"{C} [?] Month (MM): {G}")
        year = input(f"{C} [?] Year (YYYY): {G}")
        contact = input(f"{C} [?] Email/Phone: {G}")
        password = input(f"{C} [?] Password: {G}")
        
        UIComponents.show_progress("Simulating human typing and scrolling")
        time.sleep(random.uniform(3, 6))

        # بناء البيانات النهائية مع التوكن المستخرج
        payload = {
            'lsd': None, # سيتم جلبه تلقائياً من الكوكيز
            'firstname': f_name,
            'lastname': l_name,
            'birthday_day': day,
            'birthday_month': month,
            'birthday_year': year,
            'reg_email__': contact,
            'reg_passwd__': password,
            'sex': '2', # Male
            'reg_instance': reg_id,
            'submission_request': 'true',
            'helper': ''
        }

        self.submit_data(payload, contact, password)

    def submit_data(self, data, contact, pwd):
        UIComponents.show_progress("Pushing data to FB Authentication Servers")
        try:
            # الإرسال باستخدام نفس الـ session التي تحتوي على الكوكيز
            resp = self.session.post(
                "https://m.facebook.com/reg/submit/",
                data=data,
                headers=self.manager.headers,
                timeout=25
            )

            if "confirm-code" in resp.text or "checkpoint" in resp.url:
                UIComponents.show_success(f"OTP TRAP TRIGGERED! Code sent to {contact}")
                otp = input(f"{B} [▶] Enter the 5-Digit OTP: {G}")
                if len(otp) == 5:
                    self.save_result(contact, pwd, otp)
                else:
                    UIComponents.show_error("Invalid OTP format.")
            else:
                if "already_registered" in resp.text:
                    UIComponents.show_error("Email already exists. Use a fresh one.")
                else:
                    UIComponents.show_error("Request blocked. Use Mobile Data & Airplane Mode toggle.")
        
        except Exception as e:
            UIComponents.show_error(f"Fatal Network Error: {str(e)}")

    def save_result(self, user, pas, code):
        with open("database/hits.txt", "a") as f:
            f.write(f"USER: {user} | PASS: {pas} | OTP: {code} | DATE: {datetime.now()}\n")
        UIComponents.show_success("Account secured in database/hits.txt")

