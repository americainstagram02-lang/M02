        # Testing proxy against a lightweight Meta endpoint
        test_url = "https://mbasic.facebook.com/login/identify/"
        try:
            start_time = time.time()
            response = requests.get(test_url, proxies=proxy_dict, timeout=7)
            latency = time.time() - start_time
            
            # If latency > 5s, the proxy is too slow for 2026 standards
            if response.status_code == 200 and latency < 5.0:
                SystemUtils.log(f"Proxy Clean: Latency {latency:.2f}s", "DEBUG")
                return True
            return False
        except:
            return False

