# --- [ AVAILABILITY CHECKERS ] ---
class Checkers:
    @staticmethod
    def gmail(email):
        url = f"https://mail.google.com/mail/gxlu?email={email}"
        try:
            r = requests.get(url, headers={'User-Agent': BROWSER_DB[0]['User-Agent']}, timeout=10)
            if r.status_code in [429, 403]: return "BAN"
            return False if 'COMPASS' in str(r.headers) else True
        except: return "ERR"

    @staticmethod
    def mail_ru(email):
        url = f"https://account.mail.ru/api/v1/user/exists?email={email}"
        try:
            r = requests.get(url, timeout=7)
            if r.status_code == 429: return "BAN"
            return True if '"exists":false' in r.text else False
        except: return False
    @staticmethod
    def hotmail(email):
        url = "https://login.live.com/GetCredentialType.srf"
        try:
            r = requests.post(url, json={"username": email}, timeout=7)
            return True if '"IfExistsResult":5' in r.text else False
        except: return False

