class MohaMainLauncher:
    """المتحكم النهائي في واجهة المستخدم وتشغيل المهام"""
    
    def __init__(self):
        self.engine = RegistrationEngine()
        self.tools = MaintenanceTool()

    def boot(self):
        while True:
            SystemUtils.clear()
            SystemUtils.banner()
            
            # واجهة الخيارات الرئيسية
            print(f"{C} [01] START ACCOUNT CREATION (Manual Flow){X}")
            print(f"{C} [02] SYSTEM DIAGNOSTICS & INFO{X}")
            print(f"{C} [03] CLEAR LOGS & HITS DATABASE{X}")
            print(f"{R} [00] EXIT SYSTEM{X}")
            UIComponents.separator()
            
            choice = input(f"{G} [?] SELECT OPTION: {X}").strip()

            if choice in ["1", "01"]:
                self.run_engine()
            elif choice in ["2", "02"]:
                self.tools.system_info()
            elif choice in ["3", "03"]:
                self.tools.clear_database()
            elif choice in ["0", "00"]:
                print(f"\n{M} [!] Shutdown signal received. See you, Moha! {X}")
                sys.exit()
            else:
                print(f"{R} [!] Invalid entry, please try again.{X}")
                time.sleep(1)

    def run_engine(self):
        try:
            self.engine.run_manual_flow()
            UIComponents.separator()
            input(f"\n{W} Task Finished. Press [ENTER] for Menu...{X}")
        except KeyboardInterrupt:
            print(f"\n{R} [!] Operation cancelled by user.{X}")
            time.sleep(1.5)

