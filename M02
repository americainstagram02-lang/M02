            for dom in domains:
                email = f"{user}@{dom}"
                checked += 1
                
                if mode == "1": # وضع المتاحات (قابل للإنشاء + مرتبط)
                    if Mailer.is_available(email, dom):
                        linked = discovery_all_platforms(email)
                        if linked:
                            hits += 1
