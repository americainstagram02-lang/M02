class RegistrationCore:
    """
    The heart of the creation process. Handles the multi-step registration flow.
    """
    def __init__(self):
        self.interceptor = RequestInterceptor()
        self.base_url = "https://mbasic.facebook.com"
        self.reg_path = "/reg/"

    def initiate_new_account(self, target_email=None):
        # 1. Reset identity and get a clean proxy
        SystemUtils.banner()
        UIComponents.show_progress("Initializing fresh identity and proxy...")
        status = self.interceptor.refresh_identity()
        
        if status == "OUT_OF_PROXIES":
            UIComponents.show_error("No fresh proxies left in proxies.txt!")
            return False

        # 2. Generate random but realistic human data
        identity = IdentityEngine.get_random_name()
        if target_email:
            identity['email'] = target_email
        else:
            # Fallback to random hi2.in if no email provided
            identity['email'] = f"{''.join(random.choices(string.ascii_lowercase, k=7))}@hi2.in"

        UIComponents.separator()
        UIComponents.show_progress(f"Target Email : {identity['email']}")
        UIComponents.show_progress(f"Target Name  : {identity['first']} {identity['last']}")
        UIComponents.show_progress(f"Target Pass  : {identity['pass']}")
        UIComponents.separator()

        # 3. Simulate "Human Warm-up" (Visiting Home Page first)
        try:
            headers = self.interceptor.get_headers()
            UIComponents.show_progress("Phase 1: Warming up session (Visiting Home)...")
            self.interceptor.session.get(self.base_url, headers=headers, timeout=15)
            HumanBehavior.think(3, 6)

            # 4. Access Registration Form
            UIComponents.show_progress("Phase 2: Accessing registration form...")
            reg_page = self.interceptor.session.get(f"{self.base_url}{self.reg_path}", headers=headers, timeout=15)
            
            # Extract necessary hidden tokens (lsd, jazoest, etc.)
            soup = BeautifulSoup(reg_page.text, 'html.parser')
            hidden_inputs = soup.find_all('input', type='hidden')
            payload = {inp.get('name'): inp.get('value') for inp in hidden_inputs if inp.get('name')}
            
            if not payload.get('lsd'):
                UIComponents.show_error("Failed to extract security tokens (LSD missing).")
                return False

            # 5. Simulate Typing Behavior for each field
            UIComponents.show_progress("Phase 3: Filling user information (Human Speed)...")
            HumanBehavior.type_simulation("First Name")
            HumanBehavior.type_simulation("Last Name")
            HumanBehavior.type_simulation("Email Address")
            HumanBehavior.type_simulation("Birthday & Gender")
            HumanBehavior.type_simulation("Password")
            
            # Build the registration payload
            year, month, day = identity['dob'].split('-')
            payload.update({
                "firstname": identity['first'],
                "lastname": identity['last'],
                "reg_email__": identity['email'],
                "birthday_day": day,
                "birthday_month": str(int(month)),
                "birthday_year": year,
                "sex": str(random.randint(1, 2)), # 1: Female, 2: Male
                "reg_passwd__": identity['pass'],
                "submit": "Sign Up"
            })

            # Add security signature to payload
            payload['sig'] = SecurityProtocol.generate_meta_signature(payload)

            # Final check before submission (Human "Review" time)
            UIComponents.show_progress("Finalizing submission... (Human Review Time)")
            HumanBehavior.think(8, 15)

            # 6. Execute Registration Request
            UIComponents.show_progress("Phase 4: Submitting data to Meta servers...")
            final_headers = self.interceptor.get_headers(custom_referer=f"{self.base_url}{self.reg_path}")
            
            response = self.interceptor.session.post(
                f"{self.base_url}/reg/submit/",
                data=payload,
                headers=final_headers,
                timeout=25
            )

            # 7. Analyze Outcome
            outcome, detail = ResponseAnalyzer.check_outcome(response)
            
            if outcome == "SUCCESS_STEP_1":
                UIComponents.show_success("Step 1 Complete! Account created in pending mode.")
                UIComponents.show_success(f"Verification code sent to {identity['email']}.")
                
                # Save results and session
                AccountStorage.save_pending(
                    identity['email'], identity['pass'], 
                    f"{identity['first']} {identity['last']}", 
                    identity['dob'], self.interceptor.current_proxy
                )
                AccountStorage.save_session(identity['email'], self.interceptor.session, self.interceptor.hardware)
                
                UIComponents.separator()
                print(f"{G} [!] PROCESS PAUSED. PLEASE PROVIDE THE CODE MANUALLY LATER.{X}")
                return True
            
            elif outcome == "CHECKPOINT":
                UIComponents.show_error(f"Security Checkpoint: {detail}")
            elif outcome == "REJECTED":
                UIComponents.show_error(f"Registration Rejected: {detail}")
            else:
                UIComponents.show_error(f"Execution Failed: {detail}")
                
            return False

        except requests.exceptions.ProxyError:
            UIComponents.show_error("Proxy Connection Failed. Rotating...")
            return False
        except Exception as e:
            UIComponents.show_error(f"Critical Engine Error: {str(e)}")
            SystemUtils.log(f"Execution Crash: {str(e)}", "CRITICAL")
            return False

