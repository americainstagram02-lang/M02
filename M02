                                send_telegram_final(token, chat_id, res)
                        else:
                            print(f"{G} [FREE] {email} (No Platforms)", end="\r")
                    else:
                        bad += 1
                        print(f"{G} [TAKEN] {email}", end="\r")

                elif mode == "2": # وضع الكومبو (مسجل + مرتبط فقط)
                    linked = discovery_all_platforms(email)
                    if linked:
                        hits += 1
                        platforms_str = " + ".join([re.sub(r'\033\[[0-9;]*m', '', p) for p in linked])
                        res = f"REGISTERED: {email} | Linked: {platforms_str}"
                        save_and_display_hit(res, linked, email, "REGISTERED")
