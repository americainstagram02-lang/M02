class ProxyAutoGenerator:
    """Fetches free proxies if user doesn't provide a proxy list."""
    
    def __init__(self):
        self.sources = [
            "https://api.proxyscrape.com/v2/?request=getproxies&protocol=http&timeout=8000&country=all&ssl=all&anonymity=all",
            "https://www.proxyscan.io/download?type=http",
            "https://raw.githubusercontent.com/TheSpeedX/SOCKS-List/master/http.txt",
            "https://raw.githubusercontent.com/ShiftyTR/Proxy-List/master/http.txt"
        ]

    def scrape_proxies(self):
        UIComponents.show_progress("Harvesting fresh proxies for global access")
        proxies_found = []
        for url in self.sources:
            try:
                res = requests.get(url, timeout=10)
                if res.status_code == 200:
                    found = re.findall(r'\d+\.\d+\.\d+\.\d+:\d+', res.text)
                    proxies_found.extend(found)
            except:
                continue
        
        unique_list = list(set(proxies_found))
        if unique_list:
            with open(PROXY_FILE, "w") as f:
                for p in unique_list: f.write(p + "\n")
            UIComponents.show_success(f"Generated {len(unique_list)} free proxies.")
            return unique_list
        return []

class ProxyManager:
    """Manages proxy rotation and validation."""
    
    def __init__(self):
        self.generator = ProxyAutoGenerator()
        self.proxies = self.refresh()

    def refresh(self):
        if not os.path.exists(PROXY_FILE) or os.stat(PROXY_FILE).st_size == 0:
            return self.generator.scrape_proxies()
        with open(PROXY_FILE, 'r') as f:
            return [l.strip() for l in f if l.strip()]

    def get_proxy(self):
        if not self.proxies: self.proxies = self.refresh()
        if self.proxies:
            p = random.choice(self.proxies)
            return {"http": f"http://{p}", "https": f"http://{p}"}
        return None

