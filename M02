# --- Part 2: Sending Engine, Proxy Support, and Error Detection ---

class FBEnginePublic:
    def __init__(self):
        self.session = requests.Session()
        self.ua = SecurityHub.get_random_ua()

    def run(self):
        banner()
        
        # 1. Proxy Setup (Mandatory for High Success Rate)
        print(f"{Y}[!] PROXY SETTING (IP:PORT or USER:PASS@IP:PORT){X}")
        proxy_input = input(f"{W}[+] Enter Proxy (Leave blank for No Proxy): {G}")
        
        proxies = None
        if proxy_input:
            proxies = {
                "http": f"http://{proxy_input}",
                "https": f"http://{proxy_input}"
            }
            print(f"{G}[✔] Proxy Enabled.{X}")
        else:
            print(f"{R}[!] Warning: Running without proxy may reduce success rate.{X}")

        print(f"{W}--------------------------------------------{X}")

        # 2. Manual Data Entry (English Commands)
        email = input(f"{W}[?] Enter Email/Number: {G}")
        full_name = input(f"{W}[?] Enter Full Name: {G}")
        birthday = input(f"{W}[?] Enter Birthday (YYYY/MM/DD): {G}")
        password = input(f"{W}[?] Enter Password: {G}")
        
        # Process Name & Date
        try:
            f_name = full_name.split(" ")[0]
            l_name = full_name.split(" ")[1] if " " in full_name else "Account"
            y, m, d = birthday.split("/")
        except:
            print(f"\n{R}[✘] Error: Invalid Format (Name or Date).{X}")
            return

        print(f"\n{C}[*] Initializing Secure Connection...{X}")
        time.sleep(random.randint(2, 4))

        # 3. Verification Code (English Prompt)
        v_code = input(f"{B}[!] Enter Verification Code: {G}")

        # 4. Building Secure Payload
        params = {
            "api_key": "882a8490361da98702bf97a021ddc14d",
            "attempt_login": "true",
            "birthday": f"{y}-{m}-{d}",
            "client_country_code": "US", # Global Default
            "firstname": f_name,
            "lastname": l_name,
            "email": email,
            "password": password,
            "gender": random.choice(["MALE", "FEMALE"]),
            "req_friendly_name": "registerAccount",
            "locale": "en_US",
            "device_id": str(uuid.uuid4()),
            "adid": str(uuid.uuid4()),
            "v_code": v_code,
            "method": "user.register",
            "format": "json"
        }

        params["sig"] = SecurityHub.generate_sig(params)
        
        headers = {
            "User-Agent": self.ua,
            "x-fb-connection-quality": "EXCELLENT",
            "x-fb-http-engine": "Liger",
            "Authorization": "OAuth 350685531728|62f8ce9f74b12f84c123cc23437a4a32"
        }

        print(f"\n{Y}[~] Sending Registration Request...{X}")
        time.sleep(random.randint(5, 12))

        try:
            # Execution with Proxy Support
            response = self.session.post(
                "https://b-api.facebook.com/method/user.register", 
                data=params, 
                headers=headers, 
                proxies=proxies,
                timeout=30
            )
            result = response.json()

            # 5. Smart Error Detection (English)
            if "access_token" in result:
                token = result["access_token"]
                print(f"\n{G}[✔] ACCOUNT CREATED SUCCESSFULLY!{X}")
                print(f"{W}--------------------------------------------{X}")
                print(f"{G}EMAIL    : {email}{X}")
                print(f"{G}PASSWORD : {password}{X}")
                print(f"{G}TOKEN    : {token}{X}")
                print(f"{W}--------------------------------------------{X}")
                
                with open("hits_results.txt", "a") as f:
                    f.write(f"{email}|{password}|{token}\n")
            
            else:
                error_msg = result.get("error", {}).get("message", "Unknown Error")
                error_code = result.get("error", {}).get("code")

                print(f"\n{R}[✘] REGISTRATION FAILED!{X}")
                
                # Analysis Logic
                if "already_registered" in error_msg or error_code == 400:
                    print(f"{Y}[Reason]: Email already in use.{X}")
                elif "checkpoint" in error_msg:
                    print(f"{Y}[Reason]: Security Checkpoint (IP Blocked).{X}")
                elif "v_code" in error_msg:
                    print(f"{Y}[Reason]: Invalid Verification Code.{X}")
                else:
                    print(f"{Y}[Reason]: {error_msg}{X}")

        except Exception as e:
            print(f"\n{R}[!] Connection Error: {str(e)}{X}")

