# --- Proxy & Global Security Hub ---
class SecurityHub:
    @staticmethod
    def get_random_ua():
        """Generates random global User-Agents for public use"""
        android_versions = ['10', '11', '12', '13']
        brands = ['Samsung', 'Huawei', 'Oppo', 'Xiaomi', 'Vivo', 'Google']
        models = ['SM-G991B', 'VOG-L29', 'CPH2219', 'M2101K6G', 'V2105', 'Pixel 6']
        
        ver = random.choice(android_versions)
        brand = random.choice(brands)
        model = random.choice(models)
        
        ua = f"Dalvik/2.1.0 (Linux; U; Android {ver}; {model} Build/RP1A.{random.randint(111111,999999)}.001) "
        ua += f"[FBAN/FB4A;FBAV/{random.randint(350,450)}.0.0.{random.randint(10,99)}.{random.randint(100,999)};"
        ua += f"FBPN/com.facebook.katana;FBLC/en_US;FBCR/Unknown;FBMF/{brand};FBBD/{brand};FBDV/{model};FBSV/{ver};FBOP/1;FBCA/arm64-v8a:;]"
        return ua

    @staticmethod
    def generate_sig(params):
        sig = "".join(f"{k}={v}" for k, v in sorted(params.items()))
        sig += "62f8ce9f74b12f84c123cc23437a4a32" # Global Secret
        return hashlib.md5(sig.encode()).hexdigest()

