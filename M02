class ProxyManager:
    def __init__(self):
        self.proxies = []
        self.sources = [
            "https://api.proxyscrape.com/v2/?request=displayproxies&protocol=http&timeout=10000&country=all&ssl=all&anonymity=all",
            "https://www.proxy-list.download/api/v1/get?type=http",
            "https://raw.githubusercontent.com/TheSpeedX/SOCKS-List/master/http.txt"
        ]

    def scrape_proxies(self):
        """استخراج البروكسيات تلقائياً عند تشغيل الأداة"""
        print(f"{Y}[*] Scraping fresh proxies for you, Moha...{X}")
        for source in self.sources:
            try:
                response = requests.get(source, timeout=10)
                if response.status_code == 200:
                    lines = response.text.splitlines()
                    self.proxies.extend(lines)
            except:
                continue
        print(f"{G}[✔] Extracted {len(self.proxies)} proxies.{X}")

    def get_random_proxy(self):
        if self.proxies:
            px = random.choice(self.proxies)
            return {"http": f"http://{px}", "https": f"http://{px}"}
        return None

