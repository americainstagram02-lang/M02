class MohaResultHandler:
    def __init__(self):
        self.folder = "database"
        if not os.path.exists(self.folder): os.makedirs(self.folder)
        
    def save(self, category, data):
        """حفظ البيانات فوراً مع التوقيت والمنصة"""
