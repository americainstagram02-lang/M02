class HunterEngine:
    @staticmethod
    def generate_user(prefix, length):
        chars = string.ascii_lowercase + string.digits
        if not length or length <= len(prefix):
            length = len(prefix) + random.randint(3, 5)
        needed = length - len(prefix)
        return prefix + ''.join(random.choice(chars) for _ in range(needed))

def core_logic(mode, prefix, length, targets):
    global hits, bad, checked, banned, stop_thread
    
    while not stop_thread:
        try:
            user = HunterEngine.generate_user(prefix, length)
            for dom in targets:
                if stop_thread: break
                email = f"{user}@{dom}"
                checked += 1
                
                # سطر الحالة التفاعلي (بدون طباعة أسطر جديدة) لضمان نظافة الشاشة
                status = f"\r{W} [{checked}] {G}SCANNING: {S}{email} {W}| {F}HITS: {hits} {W}| {Z}BANNED: {banned}"
                sys.stdout.write(status)
                sys.stdout.flush()

                # --- نظام الصيد: متاح + مرتبط ---
                if mode == "1":
                    is_avail = False
                    if "gmail.com" in dom:
                        res = EmailCheckers.check_gmail_v8(email)
                        if res == "BANNED": banned += 1; continue
                        is_avail = res
                    elif "mail.ru" in dom: is_avail = EmailCheckers.check_mail_ru_v8(email)
                    else: is_avail = True # لبقية الدومينات غير المقيدة
                    
                    if is_avail == True:
                        # فحص المنصات إلزامي قبل الطباعة لضمان الجودة
                        found = PlatformCheckers.check_all(email)
                        if found:
                            hits += 1
                            print(f"\n{F}[HIT-AVAILABLE] {hits} : {W}{email} {F}→ {X}{' + '.join(found)}")
                            with open(RECREATE_FILE, "a") as f:
                                f.write(f"{email} | Platforms: {' + '.join(found)}\n")

                # --- نظام الصيد: مسجل + مرتبط (الكومبو) ---
                elif mode == "2":
                    found = PlatformCheckers.check_all(email)
                    if found:
                        hits += 1
                        print(f"\n{S}[HIT-COMBO] {hits} : {W}{email} {S}→ {M}{' + '.join(found)}")
                        with open(HITS_FILE, "a") as f:
                            f.write(f"{email} | Platforms: {' + '.join(found)}\n")
                    else:
                        bad += 1
            
            # موازنة السرعة لمنع حظر الـ IP على هاتف OPPO A16k
            time.sleep(0.005)
        except Exception: continue

def start_threads(mode, prefix, length, targets):
    global stop_thread
    print(f"\n{X}—"*55)
